rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId}/library/{documentId} {
      allow read: if request.auth != null
                  && request.auth.uid == userId
                  && documentId == "current";

      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && documentId == "current"
                   && request.resource.data.libraryJson is string
                   && request.resource.data.snapshotBytes is int
                   && request.resource.data.snapshotBytes <= 900000;
    }
  }
}
